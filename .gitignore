# ─── Dependencies ───────────────────────────────────────────────
node_modules/
vendor/

# ─── Build output (regenerated by `npm run build`) ──────────────
# We DO commit assets/dist so the plugin is runnable straight from a
# clone, but never commit source maps or stray build caches.
*.map
.vite/
.cache/

# ─── Release artifacts (the zip is built, not tracked) ──────────
/release/
*.zip

# ─── Secrets & local config ─────────────────────────────────────
.env
.env.*
*.local
auth.json

# ─── Editor / OS noise ──────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ─── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
debug.log

# ─── PHP tooling caches ─────────────────────────────────────────
.phpunit.result.cache
.phpcs.cache

# Internal process docs / wp.org SVN assets — not part of the public source
RELEASE-CHECKLIST.md
/screenshots/
